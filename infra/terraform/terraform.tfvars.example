# ============================================
# TSA Capstone Phoenix - Terraform Variables
# ============================================
# Copy this file to terraform.tfvars and update values
# DO NOT commit terraform.tfvars to git!

# Environment
environment = "dev"
project_name = "tsa-capstone"

# AWS Configuration
aws_region = "us-east-1"
availability_zones = ["us-east-1a", "us-east-1b"]

# Compute - Free Tier
instance_type = "t3.micro"
node_count = {
  control_plane = 1
  workers       = 2
}

# Network
vpc_cidr = "10.0.0.0/16"
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]

# SSH Configuration
ssh_key_name = "tsa-capstone-key"
ssh_public_key_path = "~/.ssh/tsa-capstone/tsa-capstone-key.pub"
ssh_private_key_path = "~/.ssh/tsa-capstone/tsa-capstone-key"
generate_ssh_key = true

# Security - REPLACE WITH YOUR IP!
allowed_ssh_ips = ["YOUR_IP_ADDRESS/32"]

# K3s Version
k3s_version = "v1.28.8+k3s1"

# Domain (optional)
domain_name = ""
hosted_zone_id = ""

# Remote State (set to true for production)
enable_remote_state = false
state_bucket_name = ""
state_lock_table = "terraform-locks"