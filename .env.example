# ============================================
# TSA Capstone Phoenix - Environment Template
# ============================================
# Copy this file to .env.dev or .env.prod and fill in values
# NEVER commit .env.* files to git!

# ============================================
# Application Secrets
# ============================================
POSTGRES_PASSWORD=CHANGE_ME
SECRET_KEY=CHANGE_ME

# ============================================
# GitHub (for CI/CD)
# ============================================
GHCR_PAT=ghp_xxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# ============================================
# AWS (for Terraform)
# ============================================
AWS_ACCESS_KEY_ID=AKIAXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxx

# ============================================
# Domain (for ingress)
# ============================================
DOMAIN_NAME=taskapp.devops-tsacademy.com
HOSTED_ZONE_ID=ZXXXXXXXXXX

# ============================================
# ArgoCD (for GitOps)
# ============================================
ARGOCD_PASSWORD=CHANGE_ME

# ============================================
# Monitoring (Grafana)
# ============================================
GRAFANA_PASSWORD=CHANGE_ME